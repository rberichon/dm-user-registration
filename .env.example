# PostgreSQL connection string.
# When running via Docker Compose this is set automatically in docker-compose.yml.
# For local development (make run), point it at your local Postgres instance.
DATABASE_URL=postgresql://user:password@localhost:5432/appdb

# Base URL of the Mailpit HTTP API used to send activation emails.
# When running via Docker Compose this is set automatically in docker-compose.yml.
# For local development (make run), Mailpit must be running separately.
MAIL_SERVICE_URL=http://localhost:8025
